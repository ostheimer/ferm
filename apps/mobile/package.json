{
  "name": "@hege/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.mkdirSync('dist', { recursive: true }); fs.copyFileSync('app.json', 'dist/app.json');\" && tsc -p tsconfig.json --noEmit",
    "dev": "expo start",
    "eas-build-post-install": "pnpm --filter @hege/domain build",
    "eas:build:development:ios": "eas build --profile development --platform ios",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@hege/domain": "workspace:*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "expo": "^53.0.17",
    "expo-dev-client": "~5.2.4",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "^14.1.5",
    "expo-linking": "55.0.11",
    "expo-local-authentication": "~16.0.5",
    "expo-location": "~18.1.6",
    "expo-router": "~5.1.11",
    "expo-status-bar": "^2.2.3",
    "expo-updates": "~0.28.18",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "babel-preset-expo": "~13.0.0",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
