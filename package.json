{
  "name": "hege",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:web": "pnpm --filter @hege/web build && pnpm --filter @hege/web start:e2e",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
