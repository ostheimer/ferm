{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["APP_DOMAIN"],
  "globalPassThroughEnv": ["DATABASE_URL", "DATABASE_URL_UNPOOLED"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
